# ============================================================
# DeepSeek API 配置
# ============================================================
# DeepSeek API 基础地址（不要改动）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称（不要改动）
DEEPSEEK_MODEL=deepseek-chat

# DeepSeek API 密钥（必填）
# 请前往 https://platform.deepseek.com 注册获取
# 将获得的 sk-xxx 密钥填入下方
DEEPSEEK_API_KEY=sk-your-api-key-here

# ============================================================
# 项目运行参数（按需修改）
# ============================================================

# 监听端口（默认 8000）
PORT=8000

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 请求超时时间（秒）
REQUEST_TIMEOUT=60

# 最大 Token 数（单次请求）
MAX_TOKENS=4096

# 温度参数（0.0 ~ 2.0，默认 0.7）
TEMPERATURE=0.7
