# ============================================================
# OpenClaw — 环境变量配置
# 复制本文件为 .env 后填入真实值
# ============================================================

# ---- DeepSeek API（必填）----
# 前往 https://platform.deepseek.com 注册获取 API Key
DEEPSEEK_API_KEY=your_api_key_here

# API 基础地址（通常无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 模型名称（通常无需修改）
DEEPSEEK_MODEL=deepseek-chat

# ---- 服务配置（按需修改）----
# Python 服务监听端口
PORT=8000

# Node.js 服务监听端口
NODE_PORT=3000

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 请求超时时间（秒）
TIMEOUT=60

# 单次请求最大 Token 数
MAX_TOKENS=4096

# 生成温度（0.0 ~ 2.0）
TEMPERATURE=0.7
